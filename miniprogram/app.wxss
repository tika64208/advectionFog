/* 全局样式变量 */
page {
  --bg-primary: #0a1628;
  --bg-secondary: #132238;
  --bg-card: rgba(19, 34, 56, 0.9);
  --text-primary: #e8f0f8;
  --text-secondary: #8ba3bf;
  --text-muted: #5a7491;
  --accent-cyan: #4dd4e6;
  --accent-blue: #64a5ff;
  --accent-purple: #a78bfa;
  --success: #34d399;
  --warning: #fbbf24;
  --danger: #f87171;
  --border-color: rgba(139, 163, 191, 0.15);
  
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用类 */
.container {
  min-height: 100vh;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-color);
}

.btn-primary {
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-blue));
  color: var(--bg-primary);
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx dashed var(--border-color);
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.btn-secondary::after {
  border: none;
}

/* 文字样式 */
.text-gradient {
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-blue), var(--accent-purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-muted {
  color: var(--text-muted);
}

.text-secondary {
  color: var(--text-secondary);
}

/* 隐藏 */
.hidden {
  display: none !important;
}
