/* 概率地图页样式 */
.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 地图 */
.fog-map {
  width: 100%;
  height: 100%;
}

/* 地图中心十字准星 */
.crosshair {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60rpx;
  height: 60rpx;
  margin-left: -30rpx;
  margin-top: -30rpx;
  pointer-events: none;
}

.crosshair-h,
.crosshair-v {
  position: absolute;
  background: rgba(77, 212, 230, 0.9);
  border-radius: 2rpx;
}

.crosshair-h {
  width: 100%;
  height: 4rpx;
  top: 50%;
  margin-top: -2rpx;
}

.crosshair-v {
  width: 4rpx;
  height: 100%;
  left: 50%;
  margin-left: -2rpx;
}

/* 拖动提示按钮 */
.drag-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%);
  margin-top: -50rpx;
  z-index: 15;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.drag-hint.show {
  opacity: 1;
}

.query-center-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #4dd4e6, #3b82f6);
  border: none;
  border-radius: 40rpx;
  padding: 20rpx 36rpx;
  font-size: 28rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(77, 212, 230, 0.4);
}

.query-center-btn .btn-icon {
  font-size: 32rpx;
}

/* 加载遮罩 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 22, 40, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(77, 212, 230, 0.2);
  border-top-color: #4dd4e6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #e0e7ff;
}

.loading-progress {
  font-size: 24rpx;
  color: rgba(224, 231, 255, 0.6);
}

/* 顶部信息栏 */
.info-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: linear-gradient(to bottom, rgba(10, 22, 40, 0.9), transparent);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
}

.location-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.location-icon {
  font-size: 32rpx;
}

.location-text {
  font-size: 28rpx;
  color: #e0e7ff;
  font-weight: 500;
}

.time-info {
  font-size: 24rpx;
  color: rgba(224, 231, 255, 0.6);
}

/* 图例面板 */
.legend-panel {
  position: absolute;
  top: calc(120rpx + env(safe-area-inset-top));
  right: 20rpx;
  background: rgba(10, 22, 40, 0.85);
  backdrop-filter: blur(10px);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(77, 212, 230, 0.2);
  z-index: 10;
}

.legend-title {
  font-size: 22rpx;
  color: rgba(224, 231, 255, 0.7);
  margin-bottom: 16rpx;
  display: block;
}

.legend-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #e0e7ff;
}

.legend-color {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  box-shadow: 0 0 12rpx currentColor;
}

.legend-color.high {
  background: radial-gradient(circle, rgba(239, 68, 68, 0.9), rgba(239, 68, 68, 0.4));
  color: rgba(239, 68, 68, 0.6);
}

.legend-color.medium {
  background: radial-gradient(circle, rgba(251, 146, 36, 0.85), rgba(251, 146, 36, 0.35));
  color: rgba(251, 146, 36, 0.5);
}

.legend-color.low {
  background: radial-gradient(circle, rgba(34, 197, 150, 0.7), rgba(34, 197, 150, 0.2));
  color: rgba(34, 197, 150, 0.4);
}

/* 底部控制栏 */
.control-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(10, 22, 40, 0.95), transparent);
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
}

.range-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.range-label {
  font-size: 24rpx;
  color: rgba(224, 231, 255, 0.7);
}

.range-options {
  display: flex;
  background: rgba(10, 22, 40, 0.8);
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid rgba(77, 212, 230, 0.3);
}

.range-option {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: rgba(224, 231, 255, 0.7);
  transition: all 0.3s ease;
}

.range-option.active {
  background: linear-gradient(135deg, #4dd4e6, #3b82f6);
  color: #fff;
}

.btn-group {
  display: flex;
  gap: 16rpx;
}

.locate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  background: rgba(77, 212, 230, 0.2);
  border: 1rpx solid rgba(77, 212, 230, 0.4);
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 0;
}

.locate-btn[disabled] {
  opacity: 0.5;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(77, 212, 230, 0.2);
  border: 1rpx solid rgba(77, 212, 230, 0.4);
  border-radius: 12rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: #4dd4e6;
}

.refresh-btn[disabled] {
  opacity: 0.5;
}

.refresh-icon {
  font-size: 28rpx;
}

/* 详情弹窗 */
.detail-popup {
  position: absolute;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  left: 20rpx;
  right: 20rpx;
  z-index: 20;
}

.popup-content {
  background: rgba(10, 22, 40, 0.95);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(77, 212, 230, 0.3);
  overflow: hidden;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid rgba(77, 212, 230, 0.2);
}

.popup-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e7ff;
}

.popup-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: rgba(224, 231, 255, 0.5);
}

.popup-body {
  padding: 24rpx 30rpx;
  display: flex;
  gap: 30rpx;
}

.popup-prob {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.popup-prob.high {
  background: rgba(239, 68, 68, 0.2);
}

.popup-prob.medium {
  background: rgba(251, 191, 36, 0.2);
}

.popup-prob.low {
  background: rgba(34, 197, 94, 0.2);
}

.prob-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #e0e7ff;
}

.popup-prob.high .prob-value {
  color: #ef4444;
}

.popup-prob.medium .prob-value {
  color: #fbbf24;
}

.popup-prob.low .prob-value {
  color: #22c55e;
}

.prob-label {
  font-size: 22rpx;
  color: rgba(224, 231, 255, 0.6);
  margin-top: 8rpx;
}

.popup-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
}

.detail-label {
  color: rgba(224, 231, 255, 0.6);
}

.detail-value {
  color: #e0e7ff;
  font-weight: 500;
}
