/* 首页样式 */
.container {
  min-height: 100vh;
  padding: 40rpx 30rpx;
  padding-bottom: 120rpx;
  position: relative;
  overflow: hidden;
}

/* 雾气背景动画 */
.fog-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.fog-layer {
  position: absolute;
  width: 200%;
  height: 100%;
  opacity: 0.5;
}

.fog-1 {
  background: radial-gradient(ellipse 80% 50% at 20% 40%, rgba(200, 220, 240, 0.08) 0%, transparent 70%);
  animation: fogDrift1 30s ease-in-out infinite;
}

.fog-2 {
  background: radial-gradient(ellipse 70% 45% at 80% 60%, rgba(160, 190, 220, 0.06) 0%, transparent 65%);
  animation: fogDrift2 45s ease-in-out infinite;
}

@keyframes fogDrift1 {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(-10%); }
}

@keyframes fogDrift2 {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(-8%); }
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.logo-icon {
  font-size: 64rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 72rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #4dd4e6, #64a5ff, #a78bfa);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 8rpx;
}

.tagline {
  color: var(--text-secondary);
  font-size: 28rpx;
  letter-spacing: 6rpx;
}

/* 搜索区域 */
.search-section {
  position: relative;
  z-index: 1;
}

.input-group {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  background: rgba(10, 22, 40, 0.6);
  border: 1rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.placeholder {
  color: var(--text-muted);
}

.search-input:focus {
  border-color: var(--accent-cyan);
}

.btn-search {
  width: 100rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--accent-cyan), var(--accent-blue));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  padding: 0;
  margin: 0;
  line-height: 88rpx;
}

.btn-search::after {
  border: none;
}

.btn-locate {
  width: 100%;
  background: transparent;
  border: 1rpx dashed var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-locate::after {
  border: none;
}

.locate-icon {
  font-size: 32rpx;
}

/* 功能入口 */
.feature-entry {
  position: relative;
  z-index: 1;
  padding: 0 !important;
  overflow: hidden;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 20rpx;
}

.feature-item:active {
  background: rgba(77, 212, 230, 0.1);
}

.feature-icon {
  font-size: 40rpx;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(77, 212, 230, 0.15);
  border-radius: 12rpx;
}

.feature-info {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.feature-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

.feature-divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 0 20rpx;
}

/* 热门城市 */
.hot-cities {
  position: relative;
  z-index: 1;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.city-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.city-item {
  background: rgba(77, 212, 230, 0.1);
  border: 1rpx solid rgba(77, 212, 230, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 28rpx;
  transition: all 0.3s;
}

.city-item:active {
  background: rgba(77, 212, 230, 0.2);
  transform: scale(0.95);
}

.city-name {
  color: var(--accent-cyan);
  font-size: 26rpx;
}

/* 科普信息 */
.info-section {
  position: relative;
  z-index: 1;
}

.info-card {
  margin-bottom: 24rpx;
}

.info-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--accent-cyan);
  margin-bottom: 16rpx;
}

.info-text {
  display: block;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.8;
}

.condition-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.condition-item {
  color: var(--text-secondary);
  font-size: 26rpx;
  padding-left: 8rpx;
}

/* 底部 */
.footer {
  position: relative;
  z-index: 1;
  text-align: center;
  padding-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.footer text {
  color: var(--text-muted);
  font-size: 22rpx;
}
